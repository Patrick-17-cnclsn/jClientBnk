<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="750.0"
      prefWidth="180.0" styleClass="main_menu_container" stylesheets="@../../Style/AdminMenu.css"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.jmc.mazebank.Controllers.Admin.AdminMenuController">
    <AnchorPane prefHeight="730.0" prefWidth="180.0" styleClass="left_container">
        <VBox prefHeight="80.0" prefWidth="160.0" styleClass="title_container" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <FontIcon iconLiteral="fas-university" iconSize="30"/>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Maze Bank"/>
        </VBox>
        <VBox layoutX="40.0" layoutY="255.0" prefHeight="400.0" prefWidth="160.0" styleClass="menu_container"
              AnchorPane.bottomAnchor="275.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="100.0">
            <Button fx:id="create_client_btn" mnemonicParsing="false" text="Create Client">
                <graphic>
                    <FontIcon iconLiteral="fas-user-plus" iconSize="16"/>
                </graphic>
            </Button>

            <Button fx:id="client_btn" mnemonicParsing="false" text="Clients">
                <graphic>
                    <FontIcon iconLiteral="fas-users" iconSize="16"/>
                </graphic>
            </Button>

            <Button fx:id="deposit_btn" mnemonicParsing="false" text="Deposit">
                <graphic>
                    <FontIcon iconLiteral="fas-money-bill-wave" iconSize="16"/>
                </graphic>
            </Button>

            <Button fx:id="logout_btn" mnemonicParsing="false" styleClass="alt_menu_btn" text="Logout"
                    textFill="#fffefe">
                <graphic>
                    <FontIcon iconLiteral="fas-sign-out-alt" iconSize="16"/>
                </graphic>
            </Button>
        </VBox>
    </AnchorPane>
</VBox>
