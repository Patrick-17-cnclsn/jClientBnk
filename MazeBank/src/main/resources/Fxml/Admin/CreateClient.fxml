<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="750.0" prefWidth="850.0" styleClass="create_client_container"
            stylesheets="@../../Style/CreateClient.css" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.jmc.mazebank.Controllers.Admin.CreateClientController">
    <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Create New Client Account" AnchorPane.leftAnchor="14.0"
          AnchorPane.topAnchor="14.0"/>
    <VBox fillWidth="false" layoutX="14.0" layoutY="45.0" prefHeight="700.0" prefWidth="600.0"
          styleClass="create_client_container">
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="First Name"/>
        <TextField fx:id="fName_fld"/>
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Last Name"/>
        <TextField fx:id="lName_fld"/>
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Password"/>
        <TextField fx:id="password_fld"/>
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Payee Adress" wrappingWidth="108.90821075439453"/>
        <CheckBox fx:id="pAddress_box" mnemonicParsing="false"/>
        <Label fx:id="pAddress_fld" styleClass="payee_adress_lbl"/>
        <CheckBox fx:id="ch_acc_box" mnemonicParsing="false" text="Add Checking Account"/>
        <Label text="Checking Account Balance"/>
        <TextField fx:id="ch_amount_fld"/>
        <CheckBox fx:id="sv_acc_box" layoutX="10.0" layoutY="161.0" mnemonicParsing="false"
                  text="Add Saving Account"/>
        <Label layoutX="10.0" layoutY="181.0" text="Saving Account Balance"/>
        <TextField fx:id="sv_amount_fld" layoutX="10.0" layoutY="198.0"/>
        <Button fx:id="create_client_btn" mnemonicParsing="false" text="Create New Client"/>
        <Label fx:id="error_lbl" styleClass="error_lbl" />
    </VBox>
</AnchorPane>
