<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="750.0"
      prefWidth="200.0" styleClass="main_menu_container" stylesheets="@../../Style/ClientMenu.css"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jmc.mazebank.Controllers.Client.ClientMenuController">
    <AnchorPane prefHeight="730.0" prefWidth="160.0" styleClass="left_container">
        <VBox prefHeight="80.0" prefWidth="160.0" styleClass="title_container" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <FontIcon iconColor="#125522" iconLiteral="fas-university" iconSize="32"
                      styleClass="login_logo_container"/>
            <Text fill="#360909" strokeType="OUTSIDE" strokeWidth="0.0" text="Maze Bank"/>
        </VBox>
        <VBox prefHeight="400.0" prefWidth="160.0" styleClass="menu_container" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="100.0">
            <Button fx:id="dashboard_btn" mnemonicParsing="false" text="Dashboard">
                <graphic>
                    <FontIcon iconLiteral="fas-home" iconSize="16"/>
                </graphic>
            </Button>
            <Button fx:id="transaction_btn" mnemonicParsing="false" text="Transactions">
                <graphic>
                    <FontIcon iconLiteral="fas-exchange-alt" iconSize="16"/>
                </graphic>
            </Button>
            <Button fx:id="accounts_btn" mnemonicParsing="false" text="Accounts">
                <graphic>
                    <FontIcon iconLiteral="fas-wallet" iconSize="16"/>
                </graphic>
            </Button>
            <Line endX="120.0"/>
            <Button fx:id="profile_btn" mnemonicParsing="false" styleClass="alt_menu_btn" text="Profile"
                    textFill="#191515">
                <graphic>
                    <FontIcon iconColor="#dbb9b9" iconLiteral="fas-user" iconSize="16"
                              styleClass="alt_menu_btn"/>
                </graphic>
                <font>
                    <Font size="1.0"/>
                </font>
            </Button>
            <Button fx:id="logout_btn" mnemonicParsing="false" styleClass="alt_menu_btn" text="Logout">
                <graphic>
                    <FontIcon iconLiteral="fas-sign-out-alt" iconSize="16"/>
                </graphic>
            </Button>
        </VBox>
        <VBox layoutX="1.0" layoutY="612.0" prefHeight="120.0" prefWidth="130.0" styleClass="report_container"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0">
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Report Suggestion/Bug?"/>
            <Label text="Use this report any errors or suggestions "/>
            <Button fx:id="report_btn" mnemonicParsing="false" text="Report">
                <graphic>
                    <FontIcon iconLiteral="fas-bug" iconSize="16"/>
                </graphic>
            </Button>
        </VBox>
    </AnchorPane>
</VBox>
